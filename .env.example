# Application Environment (development/production)
ENVIRONMENT=development

# The Anthropic API Key for accessing Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The Claude model to use for triage and ask features
CLAUDE_MODEL=claude-sonnet-4-6

# Database connection URL (Default is SQLite for local development)
DATABASE_URL=sqlite:///./tickets.db

# Slack Webhook URL for high-priority alerts (get from Slack App incoming webhooks)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Email Ingestion Settings for polling IMAP
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=support@example.com
IMAP_PASSWORD=your_email_password_here
# Email polling interval in seconds
EMAIL_POLL_INTERVAL=60

# SMTP Settings for sending replies
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=support@example.com
SMTP_PASSWORD=your_email_password_here
SMTP_FROM_EMAIL=support@example.com

# ChromaDB Settings for vector search
CHROMADB_PATH=./chroma_db
CHROMADB_COLLECTION=tickets

# Backend API host and port configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL used for CORS setup (e.g., http://localhost:5173 for local Vite dev)
FRONTEND_URL=http://localhost:5173
